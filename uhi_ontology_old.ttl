@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix bot:  <https://w3id.org/bot#> .
@prefix sosa: <http://www.w3.org/ns/sosa/> .
@prefix geo:  <http://www.opengis.net/ont/geosparql#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix unit: <http://qudt.org/vocab/unit/> .
@prefix uhi:  <http://example.org/uhi#> .
@prefix alkis: <http://example.org/alkis#> .

<http://example.org/uhi>
    a owl:Ontology ;
    rdfs:label "Urban Heat Island Risk Ontology (Stuttgart)" ;
    rdfs:comment "Extends BOT + SOSA + GeoSPARQL to model building-level heat risk for Stuttgart-Mitte." ;
    owl:imports <https://w3id.org/bot> ;
    owl:versionInfo "0.1" .


uhi:CityDistrict a owl:Class ;
    rdfs:subClassOf bot:Zone ;
    rdfs:label "City district" ;
    rdfs:comment "A named administrative sub-district of Stuttgart (Stadtbezirk)." .

uhi:AnalysisTile a owl:Class ;
    rdfs:subClassOf bot:Zone ;
    rdfs:label "LoD2 tile" ;
    rdfs:comment "A 1 km × 1 km CityGML tile from LGL BW." .

# Building already defined by BOT; we assert it is also geo:Feature
bot:Building rdfs:subClassOf geo:Feature .


uhi:measuredHeight a owl:DatatypeProperty ;
    rdfs:domain bot:Building ;
    rdfs:range  xsd:decimal ;
    rdfs:label  "measured height (m)" .

uhi:footprintArea a owl:DatatypeProperty ;
    rdfs:domain bot:Building ;
    rdfs:range  xsd:decimal ;
    rdfs:label  "footprint area (m²)" .

uhi:alkisId a owl:DatatypeProperty ;
    rdfs:domain bot:Building ;
    rdfs:range  xsd:string ;
    rdfs:label  "ALKIS / GML identifier" .

uhi:gemeindeschluessel a owl:DatatypeProperty ;
    rdfs:domain bot:Building ;
    rdfs:range  xsd:string ;
    rdfs:label  "Gemeindeschlüssel (municipality code)" .

geo:hasGeometry a owl:ObjectProperty ;
    rdfs:domain geo:Feature ;
    rdfs:range  geo:Geometry .

geo:asWKT a owl:DatatypeProperty ;
    rdfs:domain geo:Geometry ;
    rdfs:range  geo:wktLiteral .


uhi:RoofType a owl:Class ;
    rdfs:label "Roof type" .

alkis:Flachdach a uhi:RoofType ;
    rdfs:label "Flat roof"@en , "Flachdach"@de ;
    uhi:alkisCode "1000" .

alkis:Pultdach a uhi:RoofType ;
    rdfs:label "Monopitch roof"@en , "Pultdach"@de ;
    uhi:alkisCode "2100" .

alkis:Tonnendach a uhi:RoofType ;
    rdfs:label "Barrel vault roof"@en , "Tonnendach"@de ;
    uhi:alkisCode "3100" .

alkis:Kuppeldach a uhi:RoofType ;
    rdfs:label "Dome roof"@en , "Kuppeldach"@de ;
    uhi:alkisCode "3200" .

alkis:Mansarddach a uhi:RoofType ;
    rdfs:label "Mansard roof"@en , "Mansarddach"@de ;
    uhi:alkisCode "3500" .

alkis:Zeltdach a uhi:RoofType ;
    rdfs:label "Pyramid/tent roof"@en , "Zeltdach"@de ;
    uhi:alkisCode "4000" .

alkis:Mischform a uhi:RoofType ;
    rdfs:label "Mixed/complex roof form"@en , "Mischform"@de ;
    uhi:alkisCode "5000" .

alkis:UnbekannterDachtyp a uhi:RoofType ;
    rdfs:label "Unknown roof type"@en , "Unbekannt"@de ;
    uhi:alkisCode "9999" .

uhi:alkisCode a owl:DatatypeProperty ;
    rdfs:domain uhi:RoofType ;
    rdfs:range  xsd:string .

uhi:hasRoofType a owl:ObjectProperty ;
    rdfs:domain bot:Building ;
    rdfs:range  uhi:RoofType ;
    rdfs:label  "has roof type" .


uhi:BuildingFunction a owl:Class ;
    rdfs:label "Building function" .

alkis:Wohngebaeude a uhi:BuildingFunction ;
    rdfs:label "Residential building"@en , "Wohngebäude"@de ;
    rdfs:comment "ALKIS prefix 31001" .

alkis:GewerblichesGebaeude a uhi:BuildingFunction ;
    rdfs:label "Commercial/industrial building"@en , "Gewerbliches Gebäude"@de ;
    rdfs:comment "ALKIS prefix 51009" .

alkis:OeffentlichesGebaeude a uhi:BuildingFunction ;
    rdfs:label "Public building"@en , "Öffentliches Gebäude"@de .

alkis:UnbekannteFunktion a uhi:BuildingFunction ;
    rdfs:label "Unknown function"@en , "Unbekannte Funktion"@de .

uhi:hasFunction a owl:ObjectProperty ;
    rdfs:domain bot:Building ;
    rdfs:range  uhi:BuildingFunction ;
    rdfs:label  "has building function" .


uhi:HeatRiskFactor a owl:Class ;
    rdfs:label "Heat risk factor" ;
    rdfs:comment "A property of a building that contributes to urban heat island risk." .

uhi:HighAbsorptionRoof a owl:Class ;
    rdfs:subClassOf uhi:HeatRiskFactor ;
    rdfs:label "High solar absorption roof" ;
    rdfs:comment "Flat roof — maximum solar gain, minimal self-shading, poor nighttime radiation." .

uhi:LargeFootprint a owl:Class ;
    rdfs:subClassOf uhi:HeatRiskFactor ;
    rdfs:label "Large sealed footprint" ;
    rdfs:comment "Footprint > 500 m² — contributes disproportionately to surface sealing and heat retention." .

uhi:TallBuilding a owl:Class ;
    rdfs:subClassOf uhi:HeatRiskFactor ;
    rdfs:label "Tall building" ;
    rdfs:comment "Height > 20 m — contributes to urban canyon geometry, trapping longwave radiation at street level." .

uhi:hasRiskFactor a owl:ObjectProperty ;
    rdfs:domain bot:Building ;
    rdfs:range  uhi:HeatRiskFactor ;
    rdfs:label  "has heat risk factor" .


# VulnerableBuilding is inferred by a DL reasoner (HermiT), never asserted — owl:minQualifiedCardinality 2 on uhi:hasRiskFactor
uhi:VulnerableBuilding a owl:Class ;
    rdfs:label "Vulnerable building" ;
    rdfs:comment "Inferred class: a building with ≥2 heat risk factors. Not asserted directly." ;
    owl:equivalentClass [
        a owl:Class ;
        owl:intersectionOf (
            bot:Building
            [   a owl:Restriction ;
                owl:onProperty uhi:hasRiskFactor ;
                owl:minQualifiedCardinality 2 ;
                owl:onClass uhi:HeatRiskFactor
            ]
        )
    ] .


uhi:TemperatureObservation a owl:Class ;
    rdfs:subClassOf sosa:Observation ;
    rdfs:label "Daily temperature observation" .

uhi:DailyMaxTemperature a sosa:ObservableProperty ;
    rdfs:label "Daily maximum air temperature (°C)" .

uhi:HeatDayObservation a owl:Class ;
    rdfs:subClassOf uhi:TemperatureObservation ;
    rdfs:label "Heat day observation" ;
    rdfs:comment "A temperature observation where the result exceeds 30°C (DWD heat day threshold)." .

uhi:CityDistrict rdfs:subClassOf sosa:FeatureOfInterest .


uhi:impermeableSurfaceFraction a owl:DatatypeProperty ;
    rdfs:domain uhi:CityDistrict ;
    rdfs:range  xsd:decimal ;
    rdfs:label  "impermeable surface fraction (0–1)" ;
    rdfs:comment "Fraction of zone area covered by impermeable surfaces (roads, roofs, pavement). Derived from OSM." .

uhi:vegetationFraction a owl:DatatypeProperty ;
    rdfs:domain uhi:CityDistrict ;
    rdfs:range  xsd:decimal ;
    rdfs:label  "vegetation fraction (0–1)" .

uhi:treeCount a owl:DatatypeProperty ;
    rdfs:domain uhi:CityDistrict ;
    rdfs:range  xsd:integer ;
    rdfs:label  "tree count (from OSM nodes)" .

uhi:inSubdistrict a owl:ObjectProperty ;
    rdfs:domain bot:Building ;
    rdfs:range  uhi:CityDistrict ;
    rdfs:label  "building is in sub-district" .


# Disjoint sub-classes prevent counting duplicate risk factor types toward the ≥2 minimum
[   a owl:AllDisjointClasses ;
    owl:members ( uhi:HighAbsorptionRoof uhi:LargeFootprint uhi:TallBuilding )
] .

# Roof types are disjoint individuals (each building has exactly one)
[   a owl:AllDifferent ;
    owl:distinctMembers (
        alkis:Flachdach alkis:Pultdach alkis:Tonnendach
        alkis:Kuppeldach alkis:Mansarddach alkis:Zeltdach
        alkis:Mischform alkis:UnbekannterDachtyp
    )
] .

uhi:hasRoofType a owl:FunctionalProperty .
